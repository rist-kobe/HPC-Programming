# Xeon(IceLake)+A100, Nvidia HPC SDK 23.11
CC=nvc
CFLAGS=-g -Wall -c99 -O3 -mp=multicore -target=multicore -tp=icelake 
LIB=
INC=
CFLAGS += $(INC) #-gpu=cc70,sm_70,ptxinfo

.SUFFIXES: .o .c

all: run.x

run.x: mykernel.o main.o
	$(CC) $(CFLAGS) mykernel.o main.o $(LIB) -o $@	

main.o: main.c

mykernel.o: mykernel.c

.c.o:
	$(CC) $(CFLAGS) -c $< -o $@

.PHONY:
clean:
	rm -f *~ *.o *.x
