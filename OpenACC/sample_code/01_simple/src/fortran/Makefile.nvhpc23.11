# Xeon(IceLake)+A100 with Nvidia HPC SDK 23.11
FC=nvfortran
FCFLAGS=-g -acc=gpu -gpu=cc80,cuda12.3 -O0 -Minfo=accel # A100
INC=
LIN=

FCFLAGS += $(INC)
LINKOPT = $(FCFLAGS)

SRC = main.F90
OBJ = $(SRC:.F90=.o)

.SUFFIXES: .F90 .o

EXE=run.x

$(EXE): $(OBJ)
	$(FC) $(LINKOPT) -o $(EXE) $(OBJ) $(LIB)

.F90.o:
	$(FC) $(FCFLAGS) -c -o $@ $<

main.o: main.F90

.PHONY:
clean:
	rm -f *.o *.mod *~

.PHONY:
veryclean: clean
	rm -f $(EXE)
