# Xeon(IceLake)+A100, Nvidia HPC SDK 23.11
FC=nvfortran
FFLAGS=-g -Wall -O3 -acc=gpu -tp=icelake -Minfo=accel
LIB=
INC=
FFLAGS += $(INC) -gpu=cc80,cuda12.3,pinned #,ptxinfo
#

.SUFFIXES: .o .F90 .c

all: run.x

run.x: main.o
	$(FC) $(FFLAGS) -O0 main.o $(LIB) -o $@	

main.o: main.F90

.F90.o:
	$(FC) $(FFLAGS) -c $< -o $@

.PHONY:
clean:
	rm -f *~ *.o *.mod *.x
