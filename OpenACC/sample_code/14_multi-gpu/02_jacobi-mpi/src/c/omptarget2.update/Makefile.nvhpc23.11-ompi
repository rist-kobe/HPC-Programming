# Xeon(IceLake)+A100 with Nvidia HPC SDK 23.11
#export OMPI_CC=nvc
CC=mpicc #nvc
CCFLAGS=-g -c11 -fast -mp=gpu -tp=icelake -gpu=cc80,cuda12.3,pinned -Minfo=accel,mp #-cudalib=nvtx3
INC= #-DUSE_NVTX 
LIB=-lm

CCFLAGS += $(INC)

.SUFFIXES: .c .o

EXE=run.x

OBJS= main.o memory.o timer.o

$(EXE): $(OBJS)
	$(CC) $(CCFLAGS) $(OBJS) $(LIB) -o $(EXE)

main.o: memory.o main.c

memory.o: memory.c

timer.o: timer.c

.c.o:
	$(CC) $(CCFLAGS) -c $< -o $@

.PHONY:
clean:
	rm -f *.o $(EXE)
