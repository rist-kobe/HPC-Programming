# Xeon(IceLake)+A100, Nvidia HPC SDK 23.11
CC=nvc
CFLAGS=-g -Wall -c99 -O3 -mp=multicore -acc=gpu -tp=icelake -Minfo=accel
LIB=
INC=-DUSE_UNIFIED_MEM
CFLAGS += $(INC) -gpu=cc80,cuda12.3,managed,ptxinfo

.SUFFIXES: .o .c

all: run.x

run.x: mykernel.o main.o
	$(CC) $(CFLAGS) mykernel.o main.o $(LIB) -o $@	

main.o: main.c

mykernel.o: mykernel.c

.c.o:
	$(CC) $(CFLAGS) -c $< -o $@

.PHONY:
clean:
	rm -f *~ *.o *.x
