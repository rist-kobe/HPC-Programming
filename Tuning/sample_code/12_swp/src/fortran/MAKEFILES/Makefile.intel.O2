## Intel oneAPI 2022.3.1
FC=ifx
ARCHFLAGS=-mavx2 # xeon, amd64 (with AVX2)
FFLAGS=-g -warn $(ARCHFLAGS) -O2

SRC= \
	main.F90 \
	mykernel.F90 \
	mytype.F90 \
	timer.F90

OBJ=$(SRC:.F90=.o)

EXE=run.x

.SUFFIXES: .f90 .F90 .o

$(EXE): $(OBJ)
	$(FC) $(FFLAGS) $(OBJ) -o $@

.f90.o:
	$(FC) $(FFLAGS) -c $< -o $@

.F90.o:
	$(FC) $(FFLAGS) -c $< -o $@

main.o: mykernel.o mytype.o timer.o main.F90

mykernel.o: mytype.o mykernel.F90

mytype.o: mytype.F90

timer.o: mytype.o timer.F90


.PHONY:
clean:
	rm -f *.f90~ *.F90~ *.o *.mod

.PHONY:
veryclean: clean
	rm -f $(EXE)
